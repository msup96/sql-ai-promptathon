{
  "$schema": "https://github.com/Azure/data-api-builder/releases/download/v2.0.8/dab.draft.schema.json",
  "data-source": {
    "database-type": "mssql",
    "connection-string": "@env('MSSQL_CONNECTION_STRING')"
  },
  "runtime": {
    "rest": {
      "enabled": false
    },
    "graphql": {
      "enabled": false
    },
    "mcp": {
      "enabled": true,
      "dml-tools": {
        "describe-entities": true,
        "create-record": false,
        "read-records": true,
        "update-record": false,
        "delete-record": false,
        "execute-entity": true,
        "aggregate-records": {
          "enabled": true,
          "query-timeout": 30
        }
      }
    },
    "host": {
      "authentication": {
        "provider": "Unauthenticated"
      },
      "mode": "development"
    }
  },
  "autoentities": {},
  "entities": {
    "Patients": {
      "source": { "object": "dbo.Patients", "type": "table" },
      "permissions": [ { "role": "anonymous", "actions": [ { "action": "*" } ] } ]
    },
    "Staff": {
      "source": { "object": "dbo.Staff", "type": "table" },
      "permissions": [ { "role": "anonymous", "actions": [ { "action": "*" } ] } ]
    },
    "Departments": {
      "source": { "object": "dbo.Departments", "type": "table" },
      "permissions": [ { "role": "anonymous", "actions": [ { "action": "*" } ] } ]
    },
    "Encounters": {
      "source": { "object": "dbo.Encounters", "type": "table" },
      "permissions": [ { "role": "anonymous", "actions": [ { "action": "*" } ] } ]
    },
    "Equipment": {
      "source": { "object": "dbo.Equipment", "type": "table" },
      "permissions": [ { "role": "anonymous", "actions": [ { "action": "*" } ] } ]
    },
    "EquipmentMaintenanceLog": {
      "source": { "object": "dbo.EquipmentMaintenanceLog", "type": "table" },
      "permissions": [ { "role": "anonymous", "actions": [ { "action": "*" } ] } ]
    },
    "IncidentReports": {
      "source": { "object": "dbo.IncidentReports", "type": "table" },
      "permissions": [ { "role": "anonymous", "actions": [ { "action": "*" } ] } ]
    },
    "BedOccupancy": {
      "source": { "object": "dbo.BedOccupancy", "type": "table" },
      "permissions": [ { "role": "anonymous", "actions": [ { "action": "*" } ] } ]
    },
    "StaffShifts": {
      "source": { "object": "dbo.StaffShifts", "type": "table" },
      "permissions": [ { "role": "anonymous", "actions": [ { "action": "*" } ] } ]
    },
    "SupplyInventory": {
      "source": { "object": "dbo.SupplyInventory", "type": "table" },
      "permissions": [ { "role": "anonymous", "actions": [ { "action": "*" } ] } ]
    },
    "SupplyTransactions": {
      "source": { "object": "dbo.SupplyTransactions", "type": "table" },
      "permissions": [ { "role": "anonymous", "actions": [ { "action": "*" } ] } ]
    },
    "PatientSatisfactionSurveys": {
      "source": { "object": "dbo.PatientSatisfactionSurveys", "type": "table" },
      "permissions": [ { "role": "anonymous", "actions": [ { "action": "*" } ] } ]
    }
  }
}


